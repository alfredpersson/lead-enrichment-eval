# Runtime mode. `local` skips Postgres / Upstash / telemetry so the backend
# runs against just Anthropic + Voyage. `prod` requires every external below.
APP_ENV=local

# Anthropic and embedding providers (set as Modal secrets in prod).
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...

# Eval-only: powers the OpenAI grounding judge and hook coherence judge in
# services.eval. Optional — when unset, those judges are skipped and the
# scorecard degrades gracefully. Also wired into .github/workflows/eval.yml
# as the OPENAI_API_KEY secret for the nightly cron and PR gate.
OPENAI_API_KEY=sk-...

# --- Required only when APP_ENV=prod ---

# Neon Postgres pooled connection string (PgBouncer transaction mode).
# Looks like: postgresql://user:pass@<project>-pooler.<region>.aws.neon.tech/<db>?sslmode=require
DATABASE_URL=

# Upstash Redis REST credentials for per-IP rate limiting.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel-side: the Modal-issued URL after `modal deploy services/app.py`.
# For local dev, set this in web/.env.local instead (e.g. http://localhost:8000).
MODAL_BASE_URL=

# Sentry error monitoring. Both DSNs are optional — Sentry is initialised
# only when its DSN env var is set, so absent values produce a silent no-op.
# Server-side DSN (used by services/web.py inside Modal):
SENTRY_DSN=
# Browser DSN (must be NEXT_PUBLIC_ prefixed to ship to the client):
NEXT_PUBLIC_SENTRY_DSN=
# Source-map upload during Vercel builds (optional, only when set in CI):
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
