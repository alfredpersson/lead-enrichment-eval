# Runtime mode. `local` skips Postgres / Upstash / telemetry so the backend
# runs against just Anthropic + Voyage. `prod` requires every external below.
APP_ENV=local

# Anthropic and embedding providers (set as Modal secrets in prod).
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...

# --- Required only when APP_ENV=prod ---

# Neon Postgres pooled connection string (PgBouncer transaction mode).
# Looks like: postgresql://user:pass@<project>-pooler.<region>.aws.neon.tech/<db>?sslmode=require
DATABASE_URL=

# Upstash Redis REST credentials for per-IP rate limiting.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel-side: the Modal-issued URL after `modal deploy services/app.py`.
# For local dev, set this in web/.env.local instead (e.g. http://localhost:8000).
MODAL_BASE_URL=
